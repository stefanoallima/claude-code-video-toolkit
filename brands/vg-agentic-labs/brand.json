{
  "name": "VG Agentic Labs",
  "description": "AI-powered player intelligence platform for gaming studios. Cream + electric blue brand.",
  "version": "1.0.0",
  "website": "https://vgagenticlabs.xyz",

  "colors": {
    "primary": "#0000EE",
    "primaryLight": "#3b82f6",
    "primaryDark": "#00008B",
    "accent": "#d946ef",
    "textDark": "#ffffff",
    "textMedium": "#94a3b8",
    "textLight": "#64748b",
    "bgLight": "#FBFAF4",
    "bgAlt": "#1e293b",
    "bgDark": "#0f172a",
    "bgOverlay": "rgba(0, 0, 238, 0.06)",
